# LLM — set provider + model, then supply the matching API key
LLM_PROVIDER=anthropic          # anthropic | openai | google | bedrock
LLM_MODEL=claude-sonnet-4-6     # model name for the chosen provider

ANTHROPIC_API_KEY=your_key_here         # required when LLM_PROVIDER=anthropic
# OPENAI_API_KEY=your_key_here          # required when LLM_PROVIDER=openai
# GOOGLE_API_KEY=your_key_here          # required when LLM_PROVIDER=google
# AWS_ACCESS_KEY_ID=your_key_here       # required when LLM_PROVIDER=bedrock
# AWS_SECRET_ACCESS_KEY=your_key_here   # required when LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1                  # required when LLM_PROVIDER=bedrock

# Database
DATABASE_URL=postgresql+asyncpg://prism:prism_dev_password@localhost:5432/prism
POSTGRES_USER=prism
POSTGRES_PASSWORD=prism_dev_password

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# App
BASE_URL=http://localhost:8000
SECRET_KEY=change_me_in_production

# Incident systems (optional — configure what you use)
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.com
JIRA_API_TOKEN=your_token
JIRA_WEBHOOK_SECRET=your_webhook_secret

SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com
SALESFORCE_CLIENT_ID=your_client_id
SALESFORCE_CLIENT_SECRET=your_client_secret

# Data sources (optional)
SPLUNK_BASE_URL=https://splunk.yourorg.com
SPLUNK_TOKEN=your_token

DATADOG_API_KEY=your_key
DATADOG_APP_KEY=your_app_key

# Notifications (optional)
SLACK_BOT_TOKEN=xoxb-your-token
SENDGRID_API_KEY=your_key
WEBEX_BOT_TOKEN=your_token
